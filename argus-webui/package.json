{
  "name": "argus-webui",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Argus Inspector — browser UI for the on-device event stream",
  "scripts": {
    "dev": "npm run tokens && vite",
    "build": "npm run tokens && tsc --noEmit && vite build",
    "preview": "vite preview",
    "tokens": "tsx scripts/build-tokens.ts",
    "lint": "tsx scripts/lint-tokens.ts && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf": "vite --mode perf",
    "lighthouse": "lighthouse http://localhost:4173 --only-categories=performance --output=json --output-path=./lighthouse.json --chrome-flags='--headless'"
  },
  "dependencies": {
    "@preact/signals-core": "1.8.0"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "autoprefixer": "10.4.20",
    "postcss": "^8.5.13",
    "tailwindcss": "3.4.14",
    "tsx": "^4.20.0",
    "typescript": "5.5.4",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.2",
    "@rollup/rollup-darwin-x64": "4.60.2",
    "@rollup/rollup-linux-arm64-gnu": "4.60.2",
    "@rollup/rollup-linux-x64-gnu": "4.60.2"
  }
}
