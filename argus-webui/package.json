{
  "name": "argus-webui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Argus Inspector — browser UI for the on-device event stream",
  "scripts": {
    "dev": "npm run tokens && vite",
    "build": "npm run tokens && tsc --noEmit && vite build",
    "preview": "vite preview",
    "tokens": "tsx scripts/build-tokens.ts",
    "lint": "tsx scripts/lint-tokens.ts && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf": "vite --mode perf",
    "lighthouse": "lighthouse http://localhost:4173 --only-categories=performance --output=json --output-path=./lighthouse.json --chrome-flags='--headless'"
  },
  "dependencies": {
    "@preact/signals-core": "1.8.0"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.0",
    "typescript": "5.5.4",
    "vite": "5.4.10",
    "vitest": "2.1.4"
  }
}
